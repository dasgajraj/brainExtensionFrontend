<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Android 11+ (API 30) requires explicit <queries> to resolve intents
      for other apps. Without this, Linking.canOpenURL() always returns false
      for third-party email schemes (Gmail, Outlook, etc.).
    -->
    <queries>
        <!-- Any app that handles the email main/inbox intent -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_EMAIL" />
        </intent>
        <!-- Handles mailto: links (covers most email clients) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="mailto" />
        </intent>
    </queries>
    <application
      android:name=".MainApplication"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:allowBackup="false"
      android:theme="@style/AppTheme"
      android:usesCleartextTraffic="${usesCleartextTraffic}"
      android:supportsRtl="true">
      <activity
        android:name=".MainActivity"
        android:label="@string/app_name"
        android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
        android:launchMode="singleTask"
        android:windowSoftInputMode="adjustResize"
        android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
        <!-- Deep-link handler: brainextension://auth/reset-password/<token> -->
        <intent-filter>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.DEFAULT" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="brainextension" android:host="auth" />
        </intent-filter>
        <!--
          Android App Links: https://brain-extension-exng.onrender.com/auth/reset-password-bridge
          android:autoVerify="true" tells Android to verify domain ownership via
          /.well-known/assetlinks.json on the server. Once verified, tapping the
          link opens the app directly with no browser chooser.
        -->
        <intent-filter android:autoVerify="true">
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.DEFAULT" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data
                android:scheme="https"
                android:host="brain-extension-exng.onrender.com"
                android:pathPrefix="/auth/reset-password-bridge" />
        </intent-filter>
      </activity>
    </application>
</manifest>
